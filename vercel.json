{
  "version": 2,
  "builds": [
    {
      "src": "vercel/handler.go",
      "use": "@vercel/go"
    },
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "vercel/handler.go" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
