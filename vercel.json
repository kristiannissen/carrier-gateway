{
  "version": 2,
  "builds": [
    {
      "src": "cmd/api/main.go",
      "use": "@vercel/go",
      "config": { "goVersion": "1.21" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "cmd/api/main.go"
    },
    {
      "src": "/(.*)",
      "dest": "cmd/api/main.go"
    }
  ]
}
