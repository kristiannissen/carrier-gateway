{
  "version": 2,
  "routes": [
    { "src": "/api/v1/dao-bookings", "methods": ["POST"], "dest": "/api/dao_bookings.go" },
    { "src": "/api/v1/legacy-transform", "methods": ["POST"], "dest": "/api/legacy_transform.go" },
    { "src": "/api/v1/status", "methods": ["GET"], "dest": "/api/core.go" },
