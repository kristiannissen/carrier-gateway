{
  "version": 2,
  "builds": [
    {
      "src": "api/core.go",
      "use": "@vercel/go"
    },
    {
      "src": "api/dao.go",
      "use": "@vercel/go"
    },
    {
      "src": "api/budbee.go",
      "use": "@vercel/go"
    },
    {
      "src": "api/dhl.go",
      "use": "@vercel/go"
    },
    {
      "src": "api/packeta.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/api/status",
      "dest": "api/core.go"
    },
    {
      "src": "/api/service-points",
      "dest": "api/core.go"
    },
    {
      "src": "/api/tracking",
      "dest": "api/core.go"
    },
    {
      "src": "/api/dao_bookings",
      "dest": "api/dao.go"
    },
    {
      "src": "/api/budbee_bookings",
      "dest": "api/budbee.go"
    },
    {
      "src": "/api/dhl_bookings",
      "dest": "api/dhl.go"
    },
    {
      "src": "/api/packeta_bookings",
      "dest": "api/packeta.go"
    }
  ]
}
