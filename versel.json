{
  "version": 2,
  "builds": [
    { "src": "api/**/*.go", "use": "@vercel/go" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/v1/bookings", "methods": ["POST"], "dest": "/api/bookings.go" },
    { "src": "/api/v1/bookings/(?<id>[^/]+)/label", "methods": ["GET"], "dest": "/api/bookings.go?id=$id&asset=label" },
    { "src": "/api/v1/bookings/(?<id>[^/]+)/return-label", "methods": ["GET"], "dest": "/api/bookings.go?id=$id&asset=return-label" },
    { "src": "/api/v1/service-points", "methods": ["GET"], "dest": "/api/service-points.go" },
    { "src": "/api/v1/tracking/(?<id>[^/]+)", "methods": ["GET"], "dest": "/api/tracking.go?id=$id" },
    { "src": "/api/v1/status", "methods": ["GET"], "dest": "/api/status.go" },

    { "src": "/api/v1/dao-bookings", "methods": ["POST"], "dest": "/api/dao-bookings.go" },
    { "src": "/api/v1/dao-bookings/(?<id>[^/]+)/label", "methods": ["GET"], "dest": "/api/dao-bookings.go?id=$id&asset=label" },
    { "src": "/api/v1/dao-bookings/(?<id>[^/]+)/return-label", "methods": ["GET"], "dest": "/api/dao-bookings.go?id=$id&asset=return-label" },
    { "src": "/api/v1/dao-service-points", "methods": ["GET"], "dest": "/api/dao-service-points.go" },
    { "src": "/api/v1/dao-tracking/(?<id>[^/]+)", "methods": ["GET"], "dest": "/api/dao-tracking.go?id=$id" },
    { "src": "/api/v1/dao-status", "methods": ["GET"], "dest": "/api/dao-status.go" },

    { "src": "/api/v1/docs/(?<method>[^/]+)", "methods": ["GET"], "dest": "/api/docs.go?method=$method" },
    { "src": "/api/v1/docs", "methods": ["GET"], "dest": "/api/docs.go" }
  ]
}