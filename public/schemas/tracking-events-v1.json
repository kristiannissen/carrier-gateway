{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TrackingEvents",
  "type": "object",
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["state", "timestamp", "description"],
        "properties": {
          "state": {
            "type": "string",
            "enum": ["PICKED_UP", "IN_TRANSIT", "DELIVERED", "EXCEPTION"]
          },
          "timestamp": { "type": "string", "format": "date-time" },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "raw_carrier_code": { "type": "string", "description": "Original carrier event code." }
        }
      }
    }
  }
}

