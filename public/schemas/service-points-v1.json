{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ServicePointsRequestAndResponse",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "properties": {
        "carrier": { "type": "string", "enum": ["postnord"] },
        "zip_code": { "type": "string", "pattern": "^[0-9]{4}$" }
      },
      "required": ["carrier", "zip_code"]
    },
    "response": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "address": { "type": "string" }
        },
        "required": ["id", "name", "address"]
      }
    }
  }
}