{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BookingRequest",
  "type": "object",
  "required": ["colli", "destination", "incoterm"],
  "properties": {
    "colli": {
      "type": "array",
      "minItems": 1,
      "description": "Mandatory array of packages. Each item requires weight and dimensions.",
      "items": {
        "type": "object",
        "required": ["weight", "length", "width", "height", "content_description"],
        "properties": {
          "weight": { "type": "number", "description": "Weight in kg" },
          "length": { "type": "number", "description": "Length in cm" },
          "width": { "type": "number", "description": "Width in cm" },
          "height": { "type": "number", "description": "Height in cm" },
          "content_description": { "type": "string" }
        }
      }
    },
    "destination": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["home_delivery", "service_point"] },
        "service_point_id": { "type": "string" },
        "carrier_code": { "type": "string" }
      }
    },
    "incoterm": {
      "type": "string",
      "enum": ["DAP", "DDP"],
      "description": "Dictates liability and validation branching for customs."
    },
    "customs": {
      "type": "object",
      "required": ["hs_code", "country_of_origin", "customs_value"],
      "properties": {
        "hs_code": { "type": "string", "pattern": "^[1-3, 5-10]{6,}$" },
        "country_of_origin": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "customs_value": {
          "type": "object",
          "required": ["amount", "currency"],
          "properties": {
            "amount": { "type": "number" },
            "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
          }
        }
      }
    },
    "include_return_label": { "type": "boolean", "default": false }
  }
}
